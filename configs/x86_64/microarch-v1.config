# x86-64-v1 — generic x86-64 baseline (SSE2 minimum)
# Suitable for any x86-64 CPU manufactured after ~2003.
# Applied on top of the upstream Liquorix config from damentz/liquorix-package.

CONFIG_GENERIC_CPU=y
# CONFIG_MNATIVE_INTEL is not set
# CONFIG_MNATIVE_AMD is not set
CONFIG_X86_64=y

# Microarch level: v1 (SSE2 only — no level-specific optimisations)
# CONFIG_X86_64_VERSION is not set

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# CONFIG_CC_OPTIMIZE_FOR_SIZE is not set
