# x86-64-v3 — AVX, AVX2, BMI1, BMI2, FMA, MOVBE, XSAVE
# Suitable for Intel Haswell (2013+) and AMD Excavator (2015+).
# Recommended level for most modern desktops and laptops.
# Applied on top of the upstream Liquorix config from damentz/liquorix-package.

CONFIG_GENERIC_CPU3=y
CONFIG_X86_64=y

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# CONFIG_CC_OPTIMIZE_FOR_SIZE is not set
