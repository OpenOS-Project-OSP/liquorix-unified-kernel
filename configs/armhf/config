# Liquorix armhf config (32-bit ARM hard-float)
# Pulled from damentz/liquorix-package at build time for the armhf target.
# This fragment sets the baseline; the upstream script merges it with the
# Liquorix patchset config at build time.

CONFIG_ARM=y
CONFIG_ARCH_MULTI_V7=y
CONFIG_VFP=y
CONFIG_VFPv3=y
CONFIG_NEON=y
CONFIG_KERNEL_MODE_NEON=y
CONFIG_ARM_LPAE=y
CONFIG_HIGHMEM=y
CONFIG_ARCH_BCM2835=y
CONFIG_ARCH_SUNXI=y
CONFIG_ARCH_ROCKCHIP=y
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
